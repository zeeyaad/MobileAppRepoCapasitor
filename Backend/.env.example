# Database Configuration - Supabase PostgreSQL
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT_ID].supabase.co:5432/postgres

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
# Leave empty for development (auto-allows localhost and LAN IPs)
# For production, explicitly set allowed origins:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://10.100.104.157:8080
ALLOWED_ORIGINS=

# Logging
LOG_LEVEL=debug
TYPEORM_LOGGING=true

# Database Options
TYPEORM_SYNCHRONIZE=false
TYPEORM_DROP_SCHEMA=false
TYPEORM_MIGRATIONS_RUN=false
